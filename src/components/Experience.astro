---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-accent-2 text-paper border-b-4 border-ink relative overflow-hidden select-none">
      <!-- Halftone decoration -->
      <div class="absolute left-0 top-0 w-32 h-full halftone opacity-10 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          
          <!-- Left Column: Title -->
          <div class="lg:col-span-4 space-y-4">
            <div class="flex items-center gap-2">
              <span class="text-2xl text-accent animate-pulse">◆</span>
              <span class="font-mono text-xs font-bold uppercase tracking-wider text-paper/85">OUR CAPABILITIES</span>
            </div>
            <h2 class="text-4xl sm:text-5xl lg:text-7xl font-black text-paper uppercase tracking-tight leading-[0.9]">
              CAPABILITIES
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: var(--color-accent)`}
            />
          </div>

          <!-- Right Column: Timeline Cards -->
          <div class="lg:col-span-8">
            <div class="relative pl-6 border-l-4 border-ink">
              {siteConfig.experience.map((exp) => (
                <div class="relative mb-12 last:mb-0">
                  {/* Timeline dot */}
                  <div
                    class="absolute -left-[34px] top-6 w-5 h-5 bg-accent border-4 border-ink rounded-none rotate-45 z-20"
                  />

                  {/* Capability card */}
                  <div class="bg-white text-ink rounded-none border-2 border-ink p-6 sm:p-8 box-shadow-flat hover:bg-paper-2 hover:-translate-y-0.5 transition-all duration-200">
                    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-4 border-b-2 border-ink/10 pb-4">
                      <div>
                        <h3 class="text-2xl font-black font-display tracking-wide uppercase text-ink leading-tight">
                          {exp.title}
                        </h3>
                        <p
                          class="font-mono text-sm font-bold uppercase tracking-wider mt-1"
                          style={`color: var(--color-accent-2)`}
                        >
                          {exp.company}
                        </p>
                      </div>
                      <span class="font-mono text-xs font-bold text-muted mt-2 sm:mt-0 px-2 py-1 bg-gray-100 border border-gray-300">
                        {exp.dateRange}
                      </span>
                    </div>

                    <ul class="space-y-3">
                      {exp.bullets.map((bullet) => (
                        <li class="flex items-start font-mono text-sm text-ink-2 leading-relaxed">
                          <span class="inline-block text-accent-2 mr-3 font-bold">❋</span>
                          <span>{bullet}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>
  )
}
