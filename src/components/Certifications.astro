---
import { siteConfig } from "../config";
const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
const certifications = siteConfig.certifications || [];
---

{
  hasCertifications && (
    <section id="certifications" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-accent-2 text-paper border-b-4 border-ink relative overflow-hidden select-none">
      <!-- Halftone decoration -->
      <div class="absolute left-0 top-0 w-32 h-full halftone opacity-10 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          
          <!-- Left Column: Title -->
          <div class="lg:col-span-4 space-y-4">
            <div class="flex items-center gap-2">
              <span class="text-2xl text-accent animate-pulse">◆</span>
              <span class="font-mono text-xs font-bold uppercase tracking-wider text-paper/85">PARTNERS & CHECKS</span>
            </div>
            <h2 class="text-4xl sm:text-5xl lg:text-7xl font-black text-paper uppercase tracking-tight leading-[0.9]">
              CERTIFICATIONS
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: var(--color-accent)`}
            />
          </div>

          <!-- Right Column: Certification Cards -->
          <div class="lg:col-span-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {certifications.map((cert) => {
                const Card = cert.link ? "a" : "div";
                const linkProps = cert.link
                  ? {
                      href: cert.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <Card
                    {...linkProps}
                    class={`block p-6 bg-white text-ink border-2 border-ink rounded-none box-shadow-flat flex flex-col justify-between min-h-[220px] ${
                      cert.link
                        ? "hover:-translate-y-1 hover:bg-paper-2 group"
                        : ""
                    }`}
                  >
                    <div>
                      <div class="flex items-center justify-between mb-4">
                        <!-- Medal Icon container -->
                        <div
                          class="w-10 h-10 bg-accent text-ink border-2 border-ink flex items-center justify-center box-shadow-flat"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                            <circle cx="12" cy="8" r="4" />
                            <path d="M8 12l-2 9l4 -2l4 2l-2 -9" />
                            <path d="M10 12l2 9l2 -9" />
                          </svg>
                        </div>

                        <!-- Verification Arrow Indicator -->
                        {cert.link && (
                          <svg
                            class="w-4 h-4 text-ink/40 group-hover:text-accent-2 transition-colors duration-200"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        )}
                      </div>

                      <span class="text-xs font-mono text-ink-2/60 block mb-1 font-bold">
                        {cert.issuer}
                      </span>
                      <h3 class="text-xl font-black text-ink leading-tight font-display tracking-wide uppercase">
                        {cert.name}
                      </h3>
                    </div>

                    <div class="mt-6 pt-3 border-t-2 border-ink/10 flex items-center justify-between">
                      <span class="text-xs font-mono text-ink-2/50 font-bold">
                        {cert.date}
                      </span>

                      {cert.tags && cert.tags.length > 0 && (
                        <div class="flex gap-1.5">
                          {cert.tags.slice(0, 2).map((tag) => (
                            <span class="px-2 py-0.5 bg-accent text-ink border border-ink text-[10px] font-mono font-black uppercase">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </Card>
                );
              })}
            </div>
          </div>

        </div>
      </div>
    </section>
  )
}
