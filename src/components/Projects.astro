---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-accent text-ink border-b-4 border-ink relative overflow-hidden select-none">
      <!-- Halftone decoration -->
      <div class="absolute right-0 top-0 w-32 h-full halftone opacity-10 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          
          <!-- Left Column: Title -->
          <div class="lg:col-span-4 space-y-4">
            <div class="flex items-center gap-2">
              <span class="text-2xl text-accent-2 animate-pulse">◆</span>
              <span class="font-mono text-xs font-bold uppercase tracking-wider text-ink-2">OUR RELEASES</span>
            </div>
            <h2 class="text-4xl sm:text-5xl lg:text-7xl font-black text-ink uppercase tracking-tight leading-[0.9]">
              PROJECTS
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: var(--color-accent-2)`}
            />
          </div>

          <!-- Right Column: Projects Cards -->
          <div class="lg:col-span-8">
            <div class="space-y-8">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <div class="group relative">
                    <Component
                      {...linkProps}
                      class={`block relative p-6 sm:p-8 bg-white border-2 border-ink rounded-none box-shadow-flat transition-all duration-200 ${
                        project.link
                          ? "hover:-translate-y-1 hover:bg-paper-2"
                          : ""
                      }`}
                    >
                      {project.link && (
                        <div class="absolute top-4 right-4 sm:top-6 sm:right-6 w-10 h-10 flex items-center justify-center bg-accent-2 text-paper border-2 border-ink rounded-none box-shadow-flat group-hover:-translate-y-0.5 group-hover:bg-ink transition-all duration-200">
                          <svg
                            class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <div class="space-y-4">
                        <div class="flex items-baseline gap-4">
                          <span
                            class="text-4xl font-black font-display tracking-tight text-ink/20"
                          >
                            0{index + 1}
                          </span>
                          <h3 class="text-2xl sm:text-3xl font-black text-ink uppercase font-display tracking-wide">
                            {project.name}
                          </h3>
                        </div>

                        <p
                          class={`font-mono text-sm sm:text-base text-ink-2 leading-relaxed ${project.link ? "pr-12 sm:pr-14" : ""}`}
                        >
                          {project.description}
                        </p>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-3 pt-2">
                            {project.skills.map((skill) => (
                              <span
                                class="px-3 py-1 bg-accent-2 text-paper border-2 border-ink text-xs font-bold uppercase tracking-wider box-shadow-flat"
                              >
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>
          </div>

        </div>
      </div>
    </section>
  )
}
