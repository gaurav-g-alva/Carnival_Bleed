---
import { siteConfig } from "../config";

const nameParts = siteConfig.name.split(" ");
const marqueeText = [...siteConfig.skills, ...siteConfig.skills, ...siteConfig.skills].join(" ◆ ") + " ◆ ";
---

<section
  id="hero"
  class="relative isolate overflow-hidden pt-24 pb-12 min-h-screen flex flex-col justify-between"
>
  <!-- Decorative Riso Background Grid -->
  <div class="absolute inset-0 -z-10 halftone opacity-10"></div>

  <div class="max-w-7xl mx-auto w-full px-6 sm:px-8 lg:px-12 flex-grow flex flex-col justify-center gap-12 mt-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
      
      <!-- Left Column: Giant Typographic Branding -->
      <div class="lg:col-span-8 select-none">
        <h1 class="font-display font-black leading-[0.8] tracking-tighter text-ink flex flex-col">
          {nameParts.map((word) => (
            <span class="text-7xl sm:text-9xl md:text-[10rem] lg:text-[11rem] xl:text-[13rem] uppercase">
              {word}
            </span>
          ))}
        </h1>
      </div>

      <!-- Right Column: Pitch & Tagline -->
      <div class="lg:col-span-4 lg:mb-4 space-y-6">
        <div class="inline-block px-3 py-1 bg-accent-2 text-paper text-xs font-bold uppercase tracking-wider box-shadow-flat border-2 border-ink">
          ◆ ESTABLISHED 2026
        </div>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-ink leading-tight">
          {siteConfig.title}
        </h2>
        <p class="text-base sm:text-lg text-ink-2 leading-relaxed">
          {siteConfig.aboutMe}
        </p>
      </div>

    </div>

    <!-- Social Links Grid (Brutal Cards with Flat Shadow) -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-4">
      {siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          class="flex items-center justify-between p-4 bg-white border-2 border-ink hover:bg-accent hover:-translate-y-1 transition-all duration-200 box-shadow-flat group"
        >
          <span class="font-mono text-sm font-bold text-ink uppercase">Email Us</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-ink transition-transform duration-200 group-hover:translate-x-1"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
            <path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
      )}

      {siteConfig.social?.linkedin && (
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between p-4 bg-white border-2 border-ink hover:bg-accent hover:-translate-y-1 transition-all duration-200 box-shadow-flat group"
        >
          <span class="font-mono text-sm font-bold text-ink uppercase">LinkedIn</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-ink transition-transform duration-200 group-hover:translate-x-1"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M8 11v5" />
            <path d="M8 8v.01" />
            <path d="M12 16v-5" />
            <path d="M16 16v-3a2 2 0 1 0 -4 0" />
            <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
          </svg>
        </a>
      )}

      {siteConfig.social?.twitter && (
        <a
          href={siteConfig.social.twitter}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between p-4 bg-white border-2 border-ink hover:bg-accent hover:-translate-y-1 transition-all duration-200 box-shadow-flat group"
        >
          <span class="font-mono text-sm font-bold text-ink uppercase">Twitter</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-ink transition-transform duration-200 group-hover:translate-x-1"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M4 4l11.733 16h4.267l-11.733 -16z" />
            <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" />
          </svg>
        </a>
      )}

      {siteConfig.social?.github && (
        <a
          href={siteConfig.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between p-4 bg-white border-2 border-ink hover:bg-accent hover:-translate-y-1 transition-all duration-200 box-shadow-flat group"
        >
          <span class="font-mono text-sm font-bold text-ink uppercase">GitHub</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-ink transition-transform duration-200 group-hover:translate-x-1"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
          </svg>
        </a>
      )}
    </div>

  </div>

  <!-- Marquee Scroll Banner (Signature Move #7) -->
  <div class="w-full overflow-hidden border-t-4 border-b-4 border-ink py-4 bg-accent text-accent-ink mt-12 box-shadow-flat relative select-none">
    <div class="animate-marquee whitespace-nowrap flex items-center font-display text-3xl sm:text-4xl font-black tracking-widest uppercase">
      <span>{marqueeText}</span>
      <span>{marqueeText}</span>
    </div>
  </div>
</section>
