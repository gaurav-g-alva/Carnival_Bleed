---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import "../../styles/global.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const canonicalURL = new URL(Astro.url.pathname, siteConfig.siteUrl);
const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": post.data.author || siteConfig.name
  },
  "url": canonicalURL.toString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.toString()
  }
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={post.data.description} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${post.data.title} - ${siteConfig.name}`} />
    <meta property="og:description" content={post.data.description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${post.data.title} - ${siteConfig.name}`} />
    <meta property="twitter:description" content={post.data.description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@800;900&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{post.data.title} - {siteConfig.name}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />
  </head>
  <body class="bg-paper text-ink font-body min-h-screen flex flex-col justify-between">
    <Header />

    <main class="relative isolate overflow-hidden flex-grow pt-24 pb-16">
      <!-- Halftone pattern background -->
      <div class="absolute inset-0 -z-10 halftone opacity-10 pointer-events-none"></div>

      <div class="mx-auto max-w-4xl px-6 lg:px-8 mt-8 md:mt-12 select-none">
        <!-- Back Button -->
        <a
          href="/blog"
          id="back-to-blog"
          class="inline-flex items-center gap-x-2 px-4 py-2 bg-accent text-ink border-2 border-ink font-mono text-xs font-bold uppercase tracking-wider box-shadow-flat hover:bg-paper hover:-translate-y-0.5 transition-all duration-200 mb-8"
        >
          <svg
            class="w-4 h-4 transition-transform duration-200"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19l-7-7 7-7"
            />
          </svg>
          Back to all posts
        </a>

        <!-- Article Header -->
        <header class="border-b-4 border-ink pb-8">
          <div class="flex items-center gap-x-4 text-xs font-mono text-muted font-bold uppercase mb-4">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            {post.data.author && (
              <span>
                ◆ BY {post.data.author.toUpperCase()}
              </span>
            )}
          </div>
          
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-black font-display tracking-tight text-ink uppercase leading-[0.9] mt-2">
            {post.data.title}
          </h1>

          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-6">
              {post.data.tags.map((tag) => (
                <span class="px-2 py-0.5 bg-accent text-ink border border-ink text-[10px] font-mono font-black uppercase">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <!-- Article Body -->
        <div class="blog-content mt-8 select-text">
          <Content />
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* Carnival typography rules for markdown blog posts */
  .blog-content {
    font-family: var(--font-body);
  }

  .blog-content :global(p) {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-ink-2);
  }

  .blog-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    font-size: 2.25rem;
    font-weight: 800;
    font-family: var(--font-display);
    text-transform: uppercase;
    color: var(--color-ink);
    border-bottom: 3px solid var(--color-ink);
    padding-bottom: 0.25rem;
  }

  .blog-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.75rem;
    font-weight: 800;
    font-family: var(--font-display);
    text-transform: uppercase;
    color: var(--color-ink-2);
  }

  .blog-content :global(ul) {
    list-style-type: none;
    padding-left: 1rem;
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .blog-content :global(ol) {
    list-style-type: decimal;
    padding-left: 1.75rem;
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-body);
  }

  .blog-content :global(li) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-ink-2);
  }

  .blog-content :global(ul li::before) {
    content: "❋";
    color: var(--color-accent-2);
    margin-right: 0.75rem;
    font-weight: bold;
  }

  .blog-content :global(pre) {
    background-color: var(--color-paper-2);
    border: 2px solid var(--color-ink);
    padding: 1.25rem;
    overflow-x: auto;
    margin-top: 2rem;
    margin-bottom: 2rem;
    font-size: 0.85rem;
    line-height: 1.6;
    box-shadow: 4px 4px 0 var(--color-ink);
  }

  .blog-content :global(code) {
    font-family: var(--font-body);
    background-color: var(--color-accent);
    color: var(--color-ink);
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--color-ink);
    font-size: 0.9em;
    font-weight: 600;
  }

  .blog-content :global(pre code) {
    background-color: transparent;
    color: inherit;
    padding: 0;
    font-size: inherit;
    border: none;
    font-weight: normal;
  }

  .blog-content :global(blockquote) {
    border-left: 6px solid var(--color-accent-2);
    background-color: var(--color-paper-2);
    padding: 1.25rem 1.75rem;
    font-style: italic;
    color: var(--color-ink-2);
    margin-top: 2rem;
    margin-bottom: 2rem;
    box-shadow: 4px 4px 0 var(--color-ink);
    border-top: 2px solid var(--color-ink);
    border-right: 2px solid var(--color-ink);
    border-bottom: 2px solid var(--color-ink);
  }

  .blog-content :global(a) {
    color: var(--color-accent-2);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    font-weight: 700;
    transition: color 0.1s ease;
  }

  .blog-content :global(a:hover) {
    color: var(--color-ink);
    background-color: var(--color-accent);
  }

  .blog-content :global(hr) {
    border: 0;
    border-top: 2px solid var(--color-ink);
    margin: 2.5rem 0;
  }
</style>
