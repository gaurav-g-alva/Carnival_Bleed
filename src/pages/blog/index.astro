---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import { getCollection } from "astro:content";
import "../../styles/global.css";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const canonicalURL = new URL(Astro.url.pathname, siteConfig.siteUrl);
const blogDescription = `Articles and insights by ${siteConfig.name} on technology, development, and more.`;
const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${siteConfig.name} - Blog`,
  "description": blogDescription,
  "url": canonicalURL.toString(),
  "publisher": {
    "@type": "Person",
    "name": siteConfig.name
  }
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={blogDescription} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${siteConfig.name} - Blog`} />
    <meta property="og:description" content={blogDescription} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${siteConfig.name} - Blog`} />
    <meta property="twitter:description" content={blogDescription} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@800;900&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{siteConfig.name} - Blog</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />
  </head>
  <body class="bg-paper text-ink font-body min-h-screen flex flex-col justify-between">
    <Header />
    
    <main class="relative isolate overflow-hidden flex-grow pt-24 pb-16">
      <!-- Halftone pattern background -->
      <div class="absolute inset-0 -z-10 halftone opacity-10 pointer-events-none"></div>

      <div class="mx-auto max-w-6xl px-6 lg:px-8 mt-8 md:mt-16 select-none">
        <!-- Section Header -->
        <div class="border-b-4 border-ink pb-10">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-2xl text-accent-2 animate-pulse">◆</span>
            <span class="font-mono text-xs font-bold uppercase tracking-wider text-ink-2">OUR JOURNAL</span>
          </div>
          <h1 class="text-5xl sm:text-6xl md:text-7xl font-black font-display tracking-tight text-ink uppercase leading-none">
            THE BLOG
          </h1>
          <div
            class="w-[100px] h-[5px] mt-4"
            style="background-color: var(--color-accent-2)"
          >
          </div>
          <p class="mt-6 font-mono text-sm leading-relaxed text-ink-2 max-w-2xl">
            Thoughts, deep-dives, and logs about risograph printing, cassette dubbing, sound art, and visual textures.
          </p>
        </div>

        <!-- Blog Posts Grid -->
        {
          sortedPosts.length > 0 ? (
            <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {sortedPosts.map((post) => (
                <article class="group flex flex-col justify-between p-6 bg-white border-2 border-ink box-shadow-flat hover:bg-paper-2 hover:-translate-y-1 transition-all duration-200">
                  <div class="space-y-4">
                    <!-- Date & Author -->
                    <div class="flex items-center gap-x-4 text-xs font-mono text-muted font-bold uppercase">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                      {post.data.author && (
                        <span>
                          ◆ BY {post.data.author.toUpperCase()}
                        </span>
                      )}
                    </div>

                    <!-- Title -->
                    <div class="relative">
                      <h3 class="text-2xl font-black text-ink uppercase font-display leading-tight tracking-wide hover:text-accent-2 transition-colors duration-200">
                        <a href={`/blog/${post.slug}`} id={`blog-post-link-${post.slug}`}>
                          <span class="absolute inset-0" />
                          {post.data.title}
                        </a>
                      </h3>
                    </div>

                    <!-- Description -->
                    <p class="font-mono text-sm text-ink-2 leading-relaxed line-clamp-3">
                      {post.data.description}
                    </p>
                  </div>

                  <!-- Footer: Tags & Read Link -->
                  <div class="mt-6 pt-4 border-t-2 border-ink/10 flex flex-col gap-4">
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {post.data.tags.map((tag) => (
                          <span class="px-2 py-0.5 bg-accent text-ink border border-ink text-[10px] font-mono font-black uppercase">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    )}
                    <div class="flex items-center text-xs font-bold text-accent-2 font-mono uppercase tracking-wider mt-2 group-hover:underline">
                      READ POST
                      <svg
                        class="ml-1 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="mt-16 text-center py-12 bg-white border-2 border-dashed border-ink box-shadow-flat">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="mx-auto h-12 w-12 text-muted"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
                />
              </svg>
              <h3 class="mt-4 text-xl font-black font-display text-ink uppercase tracking-wide">No blog posts found</h3>
              <p class="mt-2 font-mono text-sm text-ink-2 max-w-sm mx-auto">
                Check back later or log in to the admin panel to write your first post.
              </p>
            </div>
          )
        }
      </div>
    </main>

    <Footer />
  </body>
</html>
